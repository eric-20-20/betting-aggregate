# Whop OAuth (from Developer Settings → OAuth Apps)
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=

# Whop API Key (from Developer Settings → API Keys)
WHOP_API_KEY=

# Your Whop Product ID (prod_xxxxxxxxxxxxx)
WHOP_PRODUCT_ID=

# Whop Webhook Secret (from Developer Settings → Webhooks)
WHOP_WEBHOOK_KEY=

# Public: Whop checkout URL for your product
NEXT_PUBLIC_WHOP_CHECKOUT_URL=https://whop.com/checkout/your-plan-id/

# NextAuth (generate a random 32-char string for NEXTAUTH_SECRET)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Admin bypass secret (set to enable /admin login page)
ADMIN_SECRET=

# Optional: earliest date to show in available picks (YYYY-MM-DD)
# DATA_START_DATE=2025-10-01

# Optional: site URL for canonical links and OpenGraph
# NEXT_PUBLIC_SITE_URL=https://theaggregate.xyz
