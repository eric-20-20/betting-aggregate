# Whop OAuth (from Developer Settings → OAuth Apps)
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=

# Whop API Key (from Developer Settings → API Keys)
WHOP_API_KEY=

# Your Whop Product ID (prod_xxxxxxxxxxxxx)
WHOP_PRODUCT_ID=

# Whop Webhook Secret (from Developer Settings → Webhooks)
WHOP_WEBHOOK_KEY=

# Public: Whop checkout URL for your product
NEXT_PUBLIC_WHOP_CHECKOUT_URL=https://whop.com/checkout/your-plan-id/

# NextAuth (generate a random 32-char string for NEXTAUTH_SECRET)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
